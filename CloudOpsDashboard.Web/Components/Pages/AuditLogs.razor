@page "/audit-logs"
@using System.Net.Http.Json
@using CloudOpsDashboard.Web.Models
@using CloudOpsDashboard.Web.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject ToastService ToastService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Audit Logs</PageTitle>

@if (!checkedAccess)
{
    <div class="dashboard-shell">
        <div class="loading-state">Checking administrator access...</div>
    </div>
}
else if (!isAuthorized)
{
    <div class="dashboard-shell">
        <div class="empty-card">
            <h3>Access denied</h3>
            <p>You do not have permission to view audit logs.</p>
        </div>
    </div>
}
else
{
    <div class="dashboard-shell">
        <div class="dashboard-header">
            <div>
                <h1 class="dashboard-title">📜 Audit Logs</h1>
                <div class="dashboard-subrow">
                    <span class="dashboard-subtitle">Administrative activity tracking</span>
                    <span class="sidebar-role-badge role-admin">Admin</span>
                </div>
            </div>

            <div class="page-actions">
                <button class="export-btn" @onclick="ExportAuditLogsAsync">
                    Export CSV
                </button>
            </div>
        </div>

        @if (logs is null)
        {
            <div class="loading-state">Loading audit logs...</div>
        }
        else
        {
            <div class="panel-card history-filter-card">
                <div class="panel-title">Search & Filters</div>

                <div class="history-filters-grid audit-filters-grid">
                    <input class="history-input"
                           placeholder="Search action or performed by..."
                           @bind="searchTerm"
                           @bind:event="oninput" />

                    <select class="history-select" @bind="sortOrder">
                        <option value="Newest">Newest First</option>
                        <option value="Oldest">Oldest First</option>
                    </select>
                </div>
            </div>

            @if (!FilteredLogs.Any())
            {
                <div class="empty-card">
                    <h3>No matching audit logs</h3>
                    <p>Try adjusting your search criteria.</p>
                </div>
            }
            else
            {
                <div class="panel-card audit-table-card">
                    <div class="panel-title">Recent Activity</div>

                    <div class="audit-table-wrapper">
                        <table class="audit-table">
                            <thead>
                                <tr>
                                    <th>Action</th>
                                    <th>Performed By</th>
                                    <th>Timestamp</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in FilteredLogs)
                                {
                                    <tr>
                                        <td>@log.Action</td>
                                        <td>@log.PerformedBy</td>
                                        <td>@log.Timestamp.ToLocalTime().ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private List<AuditLogItem>? logs;
    private bool checkedAccess;
    private bool isAuthorized;

    private string searchTerm = string.Empty;
    private string sortOrder = "Newest";

    private IEnumerable<AuditLogItem> FilteredLogs
    {
        get
        {
            if (logs is null)
                return Enumerable.Empty<AuditLogItem>();

            IEnumerable<AuditLogItem> query = logs;

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var term = searchTerm.Trim().ToLower();

                query = query.Where(l =>
                    (!string.IsNullOrWhiteSpace(l.Action) && l.Action.ToLower().Contains(term)) ||
                    (!string.IsNullOrWhiteSpace(l.PerformedBy) && l.PerformedBy.ToLower().Contains(term)));
            }

            query = sortOrder switch
            {
                "Oldest" => query.OrderBy(l => l.Timestamp),
                _ => query.OrderByDescending(l => l.Timestamp)
            };

            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();

        if (!isAuthenticated)
        {
            checkedAccess = true;
            Navigation.NavigateTo("/login", true);
            return;
        }

        isAuthorized = await AuthService.IsInRoleAsync("Admin");
        checkedAccess = true;

        if (isAuthorized)
        {
            logs = await Http.GetFromJsonAsync<List<AuditLogItem>>("https://localhost:7161/api/alerts/auditlogs")
                   ?? new List<AuditLogItem>();

            logs = logs
                .OrderByDescending(l => l.Timestamp)
                .ToList();
        }
    }

    private async Task ExportAuditLogsAsync()
    {
        try
        {
            var url = "https://localhost:7161/api/alerts/auditlogs/export";
            await JS.InvokeVoidAsync("downloadFileFromUrl", url);
            ToastService.ShowSuccess("Audit logs export started.");
        }
        catch
        {
            ToastService.ShowError("Failed to export audit logs.");
        }
    }
}